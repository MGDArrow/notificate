<file path="app/components/ui/UiButton.vue">
<template>
  <button
    class="ui-button"
    :class="[
      `ui-button--${variant}`,
      { 'ui-button--loading': loading, 'ui-button--disabled': disabled }
    ]"
    :disabled="disabled || loading"
    @click="emitClick"
  >
    <UiSpinner v-if="loading" size="sm" class="ui-button__spinner" />
    <slot v-else />
  </button>
</template>

<script setup lang="ts">
import type { PropType } from 'vue'

const props = defineProps({
  variant: {
    type: String as PropType<'primary' | 'secondary' | 'danger' | 'ghost'>,
    default: 'primary'
  },
  disabled: Boolean,
  loading: Boolean
})

const emit = defineEmits<{
  click: [event: MouseEvent]
}>()

function emitClick(event: MouseEvent) {
  if (!props.disabled && !props.loading) {
    emit('click', event)
  }
}
</script>

