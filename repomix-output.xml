<file path="prisma/schema.prisma">
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int            @id @default(autoincrement())
  email         String         @unique
  passwordHash  String
  createdAt     DateTime       @default(now())
  groups        Group[]
  subscriptions Subscription[]
}

model Group {
  id            Int                 @id @default(autoincrement())
  name          String
  publicKey     String              @unique
  secretKey     String              @unique
  userId        Int
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptions GroupSubscription[]
  messages      Message[]
  createdAt     DateTime            @default(now())
}

model Subscription {
  id        Int                 @id @default(autoincrement())
  endpoint  String              @unique
  keys      Json
  userId    Int? // NULL для гостей
  user      User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  groups    GroupSubscription[]
  createdAt DateTime            @default(now())
}

model GroupSubscription {
  id             Int          @id @default(autoincrement())
  groupId        Int
  group          Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  subscriptionId Int
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([groupId, subscriptionId])
}

model Message {
  id        Int      @id @default(autoincrement())
  text      String // основное содержимое (для fallback и push)
  data      Json? // полный payload (сохраняется как JSON)
  type      String? // тип, извлекаемый из data.type
  timestamp DateTime @default(now())
  groupId   Int
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
}
</file>

